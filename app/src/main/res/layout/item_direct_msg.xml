<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">
    <LinearLayout
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:id="@+id/layout_master"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_avatar_mystic"
            android:contentDescription="师傅头像"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:id="@+id/tv_msg_text"
                android:background="@drawable/bg_bubble_ai"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.4"/>
            <ImageView
                android:id="@+id/iv_msg_image"
                android:background="@drawable/bg_bubble_ai"
                android:padding="4dp"
                android:visibility="gone"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/layout_voice"
                android:background="@drawable/bg_bubble_ai"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="44dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock_black_24dp"
                    app:tint="@color/text_secondary"
                    android:contentDescription="语音消息"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_voice_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0s"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:id="@+id/layout_user"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:id="@+id/tv_msg_text_user"
                android:background="@drawable/bg_bubble_user"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/iv_msg_image_user"
                android:background="@drawable/bg_bubble_user"
                android:padding="4dp"
                android:visibility="gone"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/layout_voice_user"
                android:background="@drawable/bg_bubble_user"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="44dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock_black_24dp"
                    app:tint="@color/text_secondary"
                    android:contentDescription="语音消息"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_voice_duration_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0s"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
