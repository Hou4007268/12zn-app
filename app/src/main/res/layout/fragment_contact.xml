<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg_dark"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="联系师傅"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="选择联系方式"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/btn_wechat"
            android:background="@drawable/bg_action_item"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/nav_messages"
                android:tint="@color/gold"
                android:contentDescription="联系方式图标"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="在线客服"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ayizhaiyiju"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gold"
                android:background="@drawable/bg_gold_button"
                android:paddingLeft="16dp"
                android:paddingTop="6dp"
                android:paddingRight="16dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复制"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/btn_email"
            android:background="@drawable/bg_action_item"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_send"
                android:tint="@color/gold"
                android:contentDescription="邮箱图标"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="邮箱咨询"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hou4007268@gmail.com"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gold"
                android:background="@drawable/bg_gold_button"
                android:paddingLeft="16dp"
                android:paddingTop="6dp"
                android:paddingRight="16dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复制"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/btn_website"
            android:background="@drawable/bg_action_item"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search_black_24"
                android:tint="@color/gold"
                android:contentDescription="网站图标"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="访问网站"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12zn.com"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gold"
                android:background="@drawable/bg_gold_button"
                android:paddingLeft="16dp"
                android:paddingTop="6dp"
                android:paddingRight="16dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="打开"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>
        <Button
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:id="@+id/btn_book_consult"
            android:background="@drawable/bg_red_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="预约咨询"/>
    </LinearLayout>
</ScrollView>
