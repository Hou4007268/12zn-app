<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="一宅一句"
                android:fontFamily="serif"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="科学风水 · 真实案例 · 专业服务"
                android:letterSpacing="0.15"/>
        </LinearLayout>

        <!-- AI风水问答卡片 (置顶) -->
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/btn_ai_chat"
            android:background="@drawable/bg_gold_button"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="10dp"
            android:layout_marginHorizontal="16dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☯"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_accent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI 风水问答"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="#ccffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="随时随地，智能解答你的风水困惑"/>
                </LinearLayout>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/text_on_accent"
                    android:background="@drawable/bg_tag_transparent"
                    android:paddingLeft="8dp"
                    android:paddingTop="3dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="免费体验 ›"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 服务项目卡片 (和AI互换位置) -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_red_button"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="14dp"
            android:layout_marginHorizontal="16dp">
            <TextView
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠 13项专业服务"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#ccffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="户型风水 · 起名改名 · 择日选时 · 流年运势\n真人师傅1v1 · 八字命理 · 开光法物 · 商业风水"/>
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_accent"
                android:background="@drawable/bg_tag_transparent"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="查看全部服务 ›"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:paddingHorizontal="16dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/btn_fortune"
                android:background="@drawable/bg_action_item"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_margin="4dp"
                android:layout_weight="1">
                <TextView
                    android:textSize="28sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔮"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="今日运势"/>
                <TextView
                    android:textSize="9sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="趋吉避凶"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/btn_wuxing_test"
                android:background="@drawable/bg_action_item"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_margin="4dp"
                android:layout_weight="1">
                <TextView
                    android:textSize="28sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="万年历"/>
                <TextView
                    android:textSize="9sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="干支·宜忌"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/btn_consult"
                android:background="@drawable/bg_action_item"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_margin="4dp"
                android:layout_weight="1">
                <TextView
                    android:textSize="28sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙️"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_consult_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="预约师傅"/>
                <TextView
                    android:textSize="9sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="一对一咨询"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 更多测试 -->
        <LinearLayout
            android:gravity="center"
            android:id="@+id/btn_more_tests"
            android:padding="10dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="16dp">
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ 更多趣味测试 · 免费参与 →"/>
        </LinearLayout>

        <!-- 咨询流程 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="咨询流程"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent"
                    android:gravity="center"
                    android:background="@drawable/bg_red_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="壹"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="描述问题"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择服务类型，填写您的困惑"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent"
                    android:gravity="center"
                    android:background="@drawable/bg_red_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="贰"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI初步分析"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI助手快速给出基础方向建议"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent"
                    android:gravity="center"
                    android:background="@drawable/bg_red_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="叁"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="深度沟通"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="下载完整版获取更多专业服务"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent"
                    android:gravity="center"
                    android:background="@drawable/bg_red_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="肆"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="定制方案"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="出具完整报告，持续跟进指导"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp"/>
    </LinearLayout>
</ScrollView>
