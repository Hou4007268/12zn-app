<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_toolbar"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="登录"
            android:layout_weight="1"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
    <ScrollView
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="56sp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="☯"/>
            <TextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/gold"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="一宅一句"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="手机号"/>
            <EditText
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_gray"
                android:id="@+id/et_phone"
                android:background="@drawable/bg_input"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:hint="请输入手机号"
                android:singleLine="true"
                android:inputType="phone"
                android:paddingHorizontal="16dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layout_email"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="邮箱"/>
                <EditText
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_gray"
                    android:id="@+id/et_email"
                    android:background="@drawable/bg_input"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:hint="接收验证码的邮箱"
                    android:singleLine="true"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layout_code"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="验证码"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp">
                    <EditText
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_gray"
                        android:id="@+id/et_code"
                        android:background="@drawable/bg_input"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="请输入验证码"
                        android:singleLine="true"
                        android:layout_weight="1"
                        android:inputType="number"
                        android:paddingHorizontal="16dp"/>
                    <Button
                        android:textSize="12sp"
                        android:textColor="@color/text_on_accent"
                        android:id="@+id/btn_send_code"
                        android:background="@drawable/bg_gold_button"
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:text="发送验证码"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="密码"/>
            <EditText
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_gray"
                android:id="@+id/et_password"
                android:background="@drawable/bg_input"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:hint="输入密码"
                android:singleLine="true"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:id="@+id/tv_password_hint"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="密码需包含字母+数字+特殊符号，至少8位"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_accent"
                android:id="@+id/btn_login"
                android:background="@drawable/bg_red_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="登录"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:layout_gravity="center"
                android:id="@+id/tv_switch_mode"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="没有账号？去注册"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_gray"
                android:layout_gravity="center"
                android:id="@+id/tv_forgot"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="忘记密码？"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
