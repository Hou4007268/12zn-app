<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_toolbar"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="与张师傅对话"
            android:layout_weight="1"
            android:layout_marginStart="12dp"/>
        <ImageButton
            android:id="@+id/btn_contact"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/primary"
            android:contentDescription="联系方式"/>
    </LinearLayout>
    <View
        android:background="@color/border_soft"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:padding="16dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <View
        android:background="@color/border_soft"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageButton
            android:id="@+id/btn_voice"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/text_secondary"
            android:contentDescription="语音"/>
        <EditText
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_light"
            android:id="@+id/et_message"
            android:background="@drawable/bg_chat_input"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:hint="输入消息..."
            android:singleLine="true"
            android:layout_weight="1"
            android:imeOptions="actionSend"
            android:layout_marginStart="4dp"
            android:paddingHorizontal="16dp"/>
        <ImageButton
            android:id="@+id/btn_image"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/text_secondary"
            android:contentDescription="图片"
            android:layout_marginStart="4dp"/>
        <ImageButton
            android:id="@+id/btn_send"
            android:background="@drawable/bg_gold_button"
            android:padding="10dp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:contentDescription="发送"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/layout_recording"
        android:background="#cc000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="8dp">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_ai"
            android:padding="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:id="@+id/tv_recording_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:id="@+id/tv_recording_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="松开发送"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
