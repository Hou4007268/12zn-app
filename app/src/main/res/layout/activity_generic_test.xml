<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_toolbar"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="测试"
            android:layout_weight="1"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
    <ScrollView
        android:id="@+id/scroll_questions"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gold"
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="1/5"/>
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginBottom="24dp"
                android:max="5"
                android:progress="1"
                android:progressTint="@color/gold"
                style="?android:attr/progressBarStyleHorizontal"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:id="@+id/tv_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/options_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </ScrollView>
    <ScrollView
        android:id="@+id/result_container"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/share_card"
                android:background="@drawable/bg_card"
                android:padding="28dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="一宅一句 · 趣味测试"/>
                <TextView
                    android:textSize="56sp"
                    android:id="@+id/tv_result_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"/>
                <TextView
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:id="@+id/tv_result_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"/>
                <View
                    android:background="@color/primary"
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:id="@+id/tv_result_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">
                <Button
                    android:textSize="14sp"
                    android:textColor="@color/text_on_accent"
                    android:id="@+id/btn_share"
                    android:background="@drawable/bg_gold_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="分享给朋友"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"/>
                <Button
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:id="@+id/btn_restart"
                    android:background="@drawable/bg_outline_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="重新测试"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
            <TextView
                android:textSize="11sp"
                android:textColor="@color/text_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="结果仅供参考，放松心情最重要"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
