<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="语音/视频咨询"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="需要实时语音或视频咨询？请通过以下方式联系张师傅："
        android:lineSpacingMultiplier="1.4"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layout_wechat"
        android:background="?attr/selectableItemBackground"
        android:padding="12dp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/nav_messages"
            android:tint="@color/primary"
            android:contentDescription="微信图标"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="微信"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:id="@+id/tv_wechat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ayizhaiyiju"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="复制"/>
    </LinearLayout>
    <View
        android:background="@color/border_soft"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginVertical="4dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layout_telegram"
        android:background="?attr/selectableItemBackground"
        android:padding="12dp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_send"
            android:tint="@color/primary"
            android:contentDescription="Telegram图标"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telegram"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:id="@+id/tv_telegram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@yizhaiyiju"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打开"/>
    </LinearLayout>
</LinearLayout>
