<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="�� 玄空飞星排盘"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请输入房屋信息"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="建造年份"/>
                    <Spinner
                        android:id="@+id/sp_build_year"
                        android:background="@drawable/bg_spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="坐向"/>
                    <Spinner
                        android:id="@+id/sp_direction"
                        android:background="@drawable/bg_spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/btn_calc"
                    android:background="@drawable/bg_gold_button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="生成飞星盘"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/result_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:id="@+id/tv_period_info"
                        android:paddingBottom="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <TableLayout
                        android:padding="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="*">
                        <TableRow>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_8"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_1"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_6"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                        </TableRow>
                        <TableRow>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_7"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_center"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_2"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                        </TableRow>
                        <TableRow>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_3"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_4"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:id="@+id/tv_9"
                                android:background="@drawable/bg_cell"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_margin="2dp"
                                android:layout_weight="1"/>
                        </TableRow>
                    </TableLayout>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:id="@+id/tv_analysis"
                        android:paddingTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <Button
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:id="@+id/btn_share"
                android:background="@drawable/bg_outline_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="�� 分享飞星盘"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
