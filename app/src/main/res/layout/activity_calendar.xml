<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_toolbar"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="万年历"
            android:layout_weight="1"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
    <View
        android:background="@color/border_soft"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <ScrollView
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_pick_date"
                android:background="@drawable/bg_outline_button"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">
                <TextView
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="��"/>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:id="@+id/tv_solar_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:id="@+id/tv_lunar_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"/>
            <View
                android:background="@color/primary"
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:layout_marginTop="12dp"/>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="年柱"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_year_ganzhi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月柱"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_month_ganzhi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日柱"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_day_ganzhi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:id="@+id/tv_jieqi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/red_soft"
                    android:id="@+id/tv_chong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/green_ok"
                    android:id="@+id/tv_yi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
            <LinearLayout
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/red_soft"
                    android:id="@+id/tv_ji"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
