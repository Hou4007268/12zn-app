<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="@color/bg_toolbar"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="设置"
            android:layout_weight="1"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
    <View
        android:background="@color/border_soft"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <ScrollView
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="账号安全"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/item_change_password"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="修改密码"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" &gt;"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="我的权益"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/item_redeem"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="兑换码"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="输入兑换码领取权益 &gt;"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="聊天设置"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/item_auto_clear"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="自动清理聊天记录"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:id="@+id/tv_auto_clear_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" &gt;"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/item_clear_chat"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/red_soft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="清空所有聊天记录"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="关于"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="当前版本"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/item_check_update"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="检查更新"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" &gt;"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="官方网站"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12zn.com"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
